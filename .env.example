# ────────────────────────────────────────────────
#  PUMP.FUN RUNNER BOT — Environment Variables
# ────────────────────────────────────────────────

# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Channel ID where alerts are sent
# Right-click channel in Discord → Copy Channel ID (enable Developer Mode first)
DISCORD_CHANNEL_ID=123456789012345678

# How often to scan for new tokens (seconds). Default: 15
SCAN_INTERVAL_SECONDS=15

# Minimum runner score to trigger an alert (0-100). Default: 55
MIN_RUNNER_SCORE=55
